# Copie este arquivo para .env.local e defina as variáveis

# Segredo para assinar os tokens JWT (gere um aleatório em: openssl rand -base64 32)
AUTH_SECRET=

# Senhas dos usuários do sistema
GCJ_PASS_RODRIGO=
GCJ_PASS_SANDRA=

# URL do sistema em produção (defina no Vercel como variável de ambiente)
# NEXTAUTH_URL=https://seu-dominio.vercel.app
